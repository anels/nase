{
  "schema_version": 1,
  "name": "pr-review-core",
  "description": "Offline output-shape evals for high-frequency PR/review nase skills.",
  "cases": [
    {
      "id": "discuss-pr-problem-first",
      "skill": "nase:discuss-pr",
      "title": "Problem framing before findings",
      "prompt": "/nase:discuss-pr https://github.com/example/service/pull/123",
      "expected_output": "The review starts by framing the PR problem/context, then lists verified findings with file:line evidence and does not claim to post GitHub comments.",
      "assertions": [
        {
          "name": "problem/context appears before findings",
          "type": "ordered_regex",
          "patterns": [
            "(?im)^.*(problem|context|review frame|intent).*",
            "(?im)^.*(finding|comment draft|confirmed issue).*"
          ]
        },
        {
          "name": "has file line evidence",
          "type": "must_contain_regex",
          "pattern": "`?[^`\\s]+:\\d+`?"
        },
        {
          "name": "does not claim GitHub mutation",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(posted|commented on GitHub|resolved thread|submitted review)"
        }
      ]
    },
    {
      "id": "discuss-pr-false-positive-filter",
      "skill": "nase:discuss-pr",
      "title": "False-positive filtering",
      "prompt": "/nase:discuss-pr https://github.com/example/service/pull/124 focus on bugs only",
      "expected_output": "The review distinguishes confirmed issues from dropped or lower-confidence candidates and avoids nit-only comments.",
      "assertions": [
        {
          "name": "mentions confidence or dropped candidates",
          "type": "must_contain_regex",
          "pattern": "(?i)(confidence|dropped|false positive|pre-existing)"
        },
        {
          "name": "omits optional draft labels when bugs-only is requested",
          "type": "max_count_regex",
          "pattern": "(?is)(?:(?:comment|GitHub) draft[^\\n]*|\\*\\*File:\\*\\*[^\\n]*\\n[^\\n]*)\\b(nit|suggestion|question) \\((non-blocking|needs-answer)\\)",
          "count": 0
        },
        {
          "name": "does not use unsupported certainty",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(obviously|clearly broken without evidence|definitely exploitable)"
        }
      ]
    },
    {
      "id": "discuss-pr-verified-nit",
      "skill": "nase:discuss-pr",
      "title": "Verified nit stays explicit and non-blocking",
      "prompt": "/nase:discuss-pr https://github.com/example/service/pull/131 include worthwhile nits",
      "expected_output": "A high-confidence, PR-introduced nit cites project authority or a concrete benefit, stays non-blocking, and does not prevent approval.",
      "assertions": [
        {
          "name": "labels the nit as non-blocking",
          "type": "must_contain_regex",
          "pattern": "(?i)nit \\(non-blocking\\)"
        },
        {
          "name": "shows high confidence",
          "type": "must_contain_regex",
          "pattern": "(?i)\\[confidence (8[0-9]|9[0-9]|100)\\]"
        },
        {
          "name": "states PR introduction",
          "type": "must_contain_regex",
          "pattern": "(?i)(introduced (in|by) (this )?PR|PR-introduced)"
        },
        {
          "name": "shows authority or concrete benefit",
          "type": "must_contain_regex",
          "pattern": "(?i)(repo rule|project convention|adjacent pattern|concrete (readability|maintainability) benefit)"
        },
        {
          "name": "shows formatter or linter check",
          "type": "must_contain_regex",
          "pattern": "(?i)(formatter|linter) check:\\s*\\S"
        },
        {
          "name": "recommends approval",
          "type": "must_contain_regex",
          "pattern": "(?i)recommended state:\\s*APPROVE"
        },
        {
          "name": "does not request changes",
          "type": "must_not_contain_regex",
          "pattern": "(?i)recommended state:\\s*REQUEST_CHANGES"
        }
      ]
    },
    {
      "id": "discuss-pr-needs-answer",
      "skill": "nase:discuss-pr",
      "title": "Material unresolved question uses COMMENT",
      "prompt": "/nase:discuss-pr https://github.com/example/service/pull/132",
      "expected_output": "A material question that remains after research and prevents a merge verdict is labeled needs-answer and recommends COMMENT without claiming a blocker.",
      "assertions": [
        {
          "name": "labels the question as needs-answer",
          "type": "must_contain_regex",
          "pattern": "(?i)question \\(needs-answer\\)"
        },
        {
          "name": "recommends comment",
          "type": "must_contain_regex",
          "pattern": "(?i)recommended state:\\s*COMMENT"
        },
        {
          "name": "does not request changes",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(recommended state:\\s*REQUEST_CHANGES|confirmed must-not-merge)"
        }
      ]
    },
    {
      "id": "discuss-pr-must-not-merge",
      "skill": "nase:discuss-pr",
      "title": "Request changes requires a must-not-merge issue",
      "prompt": "/nase:discuss-pr https://github.com/example/service/pull/133",
      "expected_output": "REQUEST_CHANGES is recommended only for a PR-introduced, high-confidence blocking issue with a concrete failure and explicit must-not-merge reason.",
      "assertions": [
        {
          "name": "labels a blocking issue",
          "type": "must_contain_regex",
          "pattern": "(?i)issue \\(blocking\\)"
        },
        {
          "name": "shows high confidence",
          "type": "must_contain_regex",
          "pattern": "(?i)\\[confidence (8[0-9]|9[0-9]|100)\\]"
        },
        {
          "name": "states PR introduction",
          "type": "must_contain_regex",
          "pattern": "(?i)(introduced (in|by) (this )?PR|PR-introduced)"
        },
        {
          "name": "states concrete failure",
          "type": "must_contain_regex",
          "pattern": "(?i)Concrete failure:\\s*\\S"
        },
        {
          "name": "states explicit must-not-merge rationale",
          "type": "must_contain_regex",
          "pattern": "(?i)Why merge must wait:\\s*\\S"
        },
        {
          "name": "recommends request changes",
          "type": "must_contain_regex",
          "pattern": "(?i)recommended state:\\s*REQUEST_CHANGES"
        }
      ]
    },
    {
      "id": "discuss-pr-self-review",
      "skill": "nase:discuss-pr",
      "title": "Self-authored PR review uses COMMENT",
      "prompt": "/nase:discuss-pr https://github.com/example/service/pull/134",
      "expected_output": "A self-authored PR can publish review comments but never recommends APPROVE or REQUEST_CHANGES.",
      "assertions": [
        {
          "name": "identifies self review",
          "type": "must_contain_regex",
          "pattern": "(?i)(self-authored|self review|author matches reviewer)"
        },
        {
          "name": "recommends comment",
          "type": "must_contain_regex",
          "pattern": "(?i)recommended state:\\s*COMMENT"
        },
        {
          "name": "does not recommend unavailable states",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(recommended state:\\s*(APPROVE|REQUEST_CHANGES)|submitted(?: review)?(?: as|:)\\s*(APPROVE|REQUEST_CHANGES)|review state:\\s*(APPROVE|REQUEST_CHANGES)|\"event\"\\s*:\\s*\"(APPROVE|REQUEST_CHANGES)\")"
        }
      ]
    },
    {
      "id": "address-comments-classification",
      "skill": "nase:address-comments",
      "title": "Review thread classification before mutation",
      "prompt": "/nase:address-comments https://github.com/example/service/pull/125",
      "expected_output": "The skill presents unresolved thread classifications and asks for confirmation before code changes, replies, pushes, or resolving threads.",
      "assertions": [
        {
          "name": "classifies every thread",
          "type": "must_contain_regex",
          "pattern": "(?i)(accept|decline|reply-only)"
        },
        {
          "name": "asks for plan confirmation",
          "type": "must_contain_regex",
          "pattern": "(?i)(review the plan|confirm|proceed|looks good)"
        },
        {
          "name": "does not mutate before confirmation",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(pushed|resolved thread|posted reply|assigned reviewer)"
        }
      ]
    },
    {
      "id": "address-comments-dossier-evidence",
      "skill": "nase:address-comments",
      "title": "Deep-dive dossier before classification",
      "prompt": "/nase:address-comments https://github.com/example/service/pull/128",
      "expected_output": "The skill shows per-thread dossiers with premise, risk, evidence checked, action, and verification before asking for confirmation.",
      "assertions": [
        {
          "name": "has required dossier fields in order",
          "type": "ordered_regex",
          "patterns": [
            "(?i)Thread:",
            "(?i)Premise:",
            "(?i)Risk:",
            "(?i)Evidence checked:",
            "(?i)Decision:",
            "(?i)Action:",
            "(?i)Verification:"
          ]
        },
        {
          "name": "mentions diff/base/head evidence",
          "type": "must_contain_regex",
          "pattern": "(?i)(PR diff/base/HEAD|base.*HEAD|diff.*base)"
        },
        {
          "name": "mentions KB or repo rule evidence",
          "type": "must_contain_regex",
          "pattern": "(?i)(KB/repo rule|repo rule|KB.*none found)"
        },
        {
          "name": "mentions caller or dependency impact",
          "type": "must_contain_regex",
          "pattern": "(?i)(caller/dependency impact|caller impact|dependency impact)"
        },
        {
          "name": "does not mutate before confirmation",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(pushed|resolved thread|posted reply|gh api repos/.*/comments)"
        }
      ]
    },
    {
      "id": "address-comments-false-premise-decline",
      "skill": "nase:address-comments",
      "title": "False reviewer premise is declined with evidence",
      "prompt": "/nase:address-comments https://github.com/example/service/pull/129",
      "expected_output": "When a reviewer premise does not match the file or repo evidence, the skill declines with concrete evidence instead of accepting the suggested patch.",
      "assertions": [
        {
          "name": "declines the thread",
          "type": "must_contain_regex",
          "pattern": "(?i)\\bdecline\\b"
        },
        {
          "name": "names premise verification",
          "type": "must_contain_regex",
          "pattern": "(?i)(premise|file-vs-description|does not match|misread)"
        },
        {
          "name": "cites concrete evidence",
          "type": "must_contain_regex",
          "pattern": "(?i)(evidence|file:line|[^\\s]+:\\d+|HEAD|base)"
        },
        {
          "name": "does not use blanket out-of-scope wording",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(all declined as out of scope|scope creep, closing|not relevant, resolving)"
        }
      ]
    },
    {
      "id": "address-comments-high-risk-verifier",
      "skill": "nase:address-comments",
      "title": "High-risk or uncertain comments get verifier pass",
      "prompt": "/nase:address-comments https://github.com/example/service/pull/130",
      "expected_output": "P0/P1 or uncertain review threads are sent through a second-opinion verifier or surfaced to the user with the missing evidence before execution.",
      "assertions": [
        {
          "name": "uses risk tier",
          "type": "must_contain_regex",
          "pattern": "(?i)P[01].*(security|data-loss|correctness|runtime)"
        },
        {
          "name": "mentions second opinion or fallback verifier",
          "type": "must_contain_regex",
          "pattern": "(?i)(second-opinion|Codex|fallback-verify|verifier)"
        },
        {
          "name": "does not silently accept uncertainty",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(unclear but accepting|probably fine, accepting|accepting without evidence)"
        }
      ]
    },
    {
      "id": "request-review-draft-style",
      "skill": "nase:request-review",
      "title": "Concise review-request draft",
      "prompt": "/nase:request-review https://github.com/example/service/pull/126",
      "expected_output": "The skill selects candidate reviewers, shows a concise Slack draft, and uses draft/send-gate language.",
      "assertions": [
        {
          "name": "uses review or approval ask",
          "type": "must_contain_regex",
          "pattern": "(?i)Could you help (review|approve)"
        },
        {
          "name": "includes a raw PR URL",
          "type": "must_contain_regex",
          "pattern": "https://github\\.com/[^\\s]+/pull/[0-9]+"
        },
        {
          "name": "does not directly send Slack",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(sent DM|slack_send_message\\b)"
        },
        {
          "name": "does not use redundant this question",
          "type": "must_not_contain_regex",
          "pattern": "(?i)Could you help (review|approve) this\\?"
        }
      ]
    },
    {
      "id": "prep-merge-safety-gates",
      "skill": "nase:prep-merge",
      "title": "Merge-prep safety gates",
      "prompt": "/nase:prep-merge https://github.com/example/service/pull/127",
      "expected_output": "The skill reports branch, unresolved-thread, CI, and protected-branch safety checks before any merge-prep mutation.",
      "assertions": [
        {
          "name": "checks unresolved comments or threads",
          "type": "must_contain_regex",
          "pattern": "(?i)(unresolved.*(comment|thread)|review thread)"
        },
        {
          "name": "checks branch or protected branch safety",
          "type": "must_contain_regex",
          "pattern": "(?i)(branch|protected|main|develop|release/)"
        },
        {
          "name": "does not claim merge completed",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(merged successfully|merge completed|deleted branch)"
        }
      ]
    },
    {
      "id": "tech-debt-ai-verification-section",
      "skill": "nase:tech-debt-audit",
      "title": "AI verification debt section",
      "prompt": "/nase:tech-debt-audit example-service",
      "expected_output": "The saved audit includes an AI Verification Debt section with explicit provenance, verification gaps, risk, and next checks.",
      "assertions": [
        {
          "name": "has AI verification debt section",
          "type": "must_contain_regex",
          "pattern": "(?i)AI Verification Debt"
        },
        {
          "name": "tracks provenance and verification gap",
          "type": "must_contain_regex",
          "pattern": "(?i)(ai_provenance|Explicit AI provenance)[\\s\\S]*(verification_gap|Missing verification)"
        },
        {
          "name": "tracks recommended next check",
          "type": "must_contain_regex",
          "pattern": "(?i)(recommended_next_check|Recommended repayment order|next check)"
        },
        {
          "name": "does not infer AI authorship from style",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(looks AI|AI-looking|style suggests AI|probably AI-authored|seems generated)"
        }
      ]
    },
    {
      "id": "tech-debt-no-ai-provenance",
      "skill": "nase:tech-debt-audit",
      "title": "No AI provenance means none-found",
      "prompt": "/nase:tech-debt-audit example-service --scope src/payments",
      "expected_output": "When no explicit AI artifact is found, the audit records none-found and still reports ordinary verification gaps without labeling them AI-authored.",
      "assertions": [
        {
          "name": "uses none-found provenance",
          "type": "must_contain_regex",
          "pattern": "(?i)(ai_provenance:\\s*none-found|Explicit AI provenance found:\\s*no|none-found)"
        },
        {
          "name": "can still report verification gaps",
          "type": "must_contain_regex",
          "pattern": "(?i)(missing-tests|missing-scanner|missing-runtime-proof|Missing verification|verification gap)"
        },
        {
          "name": "does not label code as AI-sourced",
          "type": "must_not_contain_regex",
          "pattern": "(?i)(AI-authored because|generated-looking|likely AI code)"
        }
      ]
    }
  ]
}
